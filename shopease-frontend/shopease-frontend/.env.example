# ShopEase Frontend Environment Variables
# Copy this file to .env and update the values

# For web development (localhost)
VITE_API_BASE_URL=http://localhost:5000/api

# For Capacitor Android (physical device on same WiFi)
# Replace 192.168.1.X with your computer actual local IP
# VITE_API_BASE_URL=http://192.168.1.X:5000/api

# For Capacitor Android (production deployed backend)
# VITE_API_BASE_URL=https://your-deployed-backend.com/api