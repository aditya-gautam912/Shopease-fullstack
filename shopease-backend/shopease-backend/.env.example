# ─── ShopEase Backend Environment Variables ───
# Copy this file to .env and fill in your values

PORT=5000
MONGO_URI=mongodb://localhost:27017/shopease
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_different_from_jwt_secret
CSRF_SECRET=your_csrf_secret_change_this_in_production
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ─── Email Configuration (for notifications) ──────────────
# Use Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM="ShopEase <noreply@shopease.com>"

# ─── OAuth Configuration (for social authentication) ───────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ─── Razorpay (required for real payments) ────────────────
# Sign up free at https://dashboard.razorpay.com
# Use TEST mode keys during development (no real money)
RAZORPAY_KEY_SECRET=gDyRvj052AVvmlvH8LoK4G4z
RAZORPAY_KEY_ID=rzp_test_SWKVIU9ybHY21D